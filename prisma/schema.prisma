generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                  @id @unique @default(uuid())
  isActive          Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  fullName          String                     
  email             String                  @unique
  hashedPassword    String
  isPaidUser        Boolean                 @default(false)
  role              UserRole                @default(paid)
}

enum UserRole {
  notPaid
  paid
}

model Currency {
  id                  String   @id @default(uuid())
  name                String
  short_code          String   @unique
  code                String
  precision           Int
  symbol              String
  symbol_first        Boolean
  decimal_mark        String
  thousands_separator String
  rate                Float
  createdAt           DateTime @default(now())    // Para rastrear quando a moeda foi adicionada
  updatedAt           DateTime @updatedAt
}

model Employee {
  id                String                  @id @unique @default(uuid())
  isActive          Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  email             String                  @unique
  hashedPassword    String
  employeeNumber    Int                     @unique
  jobTitle          EmployeeRole            @default(NOT_ASSIGNED)
}

enum EmployeeRole {
  ADMIN
  PROGRAMMER
  CUSTOMER_SUPPORT
  NOT_ASSIGNED
}

model FunctionValidation {
  id               String            @id @unique @default(uuid())
  functionName     String      
  validations      ValidationItem[] 
}

model ValidationItem {
  id                        String            @id @unique @default(uuid())
  validation                String         
  status                    FunctionStatus    @default(PENDING) 
  function                  FunctionValidation @relation(fields: [functionValidationId], references: [id])
  functionValidationId      String      
}

enum FunctionStatus {
  PENDING        
  ACTIVE           
  INACTIVE         
}