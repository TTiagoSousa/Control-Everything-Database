generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                  @id @unique @default(uuid())
  isActive          Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  fullName          String                     
  email             String                  @unique
  hashedPassword    String
  isPaidUser        Boolean                 @default(false)
  role              UserRole                @default(paid)
}

enum UserRole {
  notPaid
  paid
}

model Currency {
  id              String   @id @default(uuid())
  code            String   @unique
  symbol          String
  name            String
  symbol_native   String
  decimal_digits  Int
  rounding        Int
  name_plural     String
  type            String
  rate            Float
  createdAt       DateTime @default(now())    // For tracking when the currency was added
  updatedAt       DateTime @updatedAt
}